# Optional. Local development defaults to the Mintlify preview server at http://localhost:3333.
# Set this to https://docs.buffer.lol when the docs subdomain is ready.
NEXT_PUBLIC_DOCS_URL=

# Optional production hardening for server-backed diagnostics.
# When both Upstash values are set, API rate limits coordinate across serverless replicas.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Proxy IP headers are ignored unless this is true or TRUSTED_PROXY_PLATFORM is vercel/netlify/cloudflare.
TRUST_PROXY_HEADERS=
TRUSTED_PROXY_PLATFORM=netlify

# Worker-only ICMP/traceroute tools remain disabled unless these are configured.
ENABLE_WORKER_TOOLS=false
DIAGNOSTICS_WORKER_URL=
DIAGNOSTICS_WORKER_TOKEN=

# Per-instance safety valve for live diagnostics work.
DIAGNOSTICS_MAX_CONCURRENCY=20
